GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash

# Runtime profile and logging
APP_ENV=local
LOG_LEVEL=INFO
APP_DATABASE_PATH=data/app.sqlite3

# Reliability controls
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=0.25
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_SECONDS=30

# URL ingestion safety
URL_TIMEOUT_SECONDS=10
URL_RETRY_MAX_ATTEMPTS=2
BLOCK_PRIVATE_URLS=true

# Local background processing
BACKGROUND_WORKER_COUNT=2

# Comma-separated response locales exposed in the UI
SUPPORTED_LANGUAGES=en,hi-en,es

# Scanned PDF OCR and layout extraction
PDF_OCR_ENABLED=true
PDF_OCR_MIN_TEXT_CHARACTERS=40

# Per-process safety budgets; use a shared Redis limiter when horizontally scaled
QUERY_RATE_LIMIT_PER_MINUTE=30
UPLOAD_RATE_LIMIT_PER_MINUTE=10
BACKGROUND_MAX_PENDING_JOBS=20
